generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Kullanıcılar (Admin + Öğrenci)
// ============================================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  tcNo          String?   // TC Kimlik No (sipariş/fatura için)
  address       String?   @db.Text
  city          String?
  district      String?
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]
  courseAccess  CourseAccess[]
}

enum Role {
  ADMIN
  STUDENT
}

// ============================================
// Kurs Kategorileri
// ============================================
model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  parentId  String?
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("SubCategories")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Kurslar (KURS + FLIX + KAMP birleşik)
// ============================================
enum CourseType {
  KURS
  FLIX
  KAMP
}

model Course {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  subtitle    String?    @db.Text  // Kısa alt başlık
  description String?    @db.Text
  price       Float
  oldPrice    Float?     // İndirimli fiyat gösterimi için
  imageUrl    String?
  gallery     Json?      // Çoklu görsel yüklemeleri için array [url1, url2...]
  videoUrl    String?    // Tanıtım videosu URL
  category    String?
  type        CourseType  @default(KURS)
  isActive    Boolean    @default(true)
  isCouponApplicable Boolean @default(true)
  sortOrder          Int        @default(999)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Dinamik Tasarım
  color       String?    @default("#3B82F6")
  emoji       String?    

  // FLIX / KAMP ek alanları
  hours        String?   // "3.500+"
  questions    String?   // "12.000+"
  bookPrice    Float?    // Kitap seti fiyatı
  badge        String?   // "En Popüler", "Yeni", "Çok Satan"
  duration     String?   // Kamp süresi (saat)
  studentCount String?   // Kamp öğrenci sayısı
  resources    String?   // Kaynak sayısı "120"

  // Detay sayfası zengin içerikler (JSON)
  features         Json?  // ["Bire Bir Koçluk", "Deneme Sınavları", ...]
  bentoFeatures    Json?  // [{icon, title, subtitle}, ...]
  learningOutcomes Json?  // ["Kazanım 1", "Kazanım 2", ...]
  curriculum       Json?  // [{title, duration}, ...]
  instructor       Json?  // {name, title, image, bio, rating, students}
  instructorList   String? @db.Text

  // FLIX'e özel
  episodes         Json?  // [{title, duration, description, locked}, ...]
  cast             Json?  // [{name, role, img}, ...]
  tags             Json?  // ["Hukuk", "Adli Yargı", "2024"]

  // FLIX Yönlendirme (Upsell Smart Bar)
  flixUpsellText   String? @db.Text
  flixUpsellLink   String?

  // Erişim Yönetimi
  accessEndDate      DateTime?  // Sabit bitiş tarihi (KURS tipi: sınav tarihi vb.)
  accessDurationDays Int?       // Satın almadan itibaren kaç gün erişim (FLIX tipi)

  orderItems   OrderItem[]
  courseAccess CourseAccess[]

  variants     CourseVariant[]
  addons       CourseAddon[]
  coupons      Coupon[]
}

model CourseVariant {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  price       Float
  oldPrice    Float?
  order       Int      @default(0)

  accessDurationDays Int?     // Satın alındığında eklenecek gün sayısı (Örn: 90)

  orderItems  OrderItem[]

  @@index([courseId])
}

model CourseAddon {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  price       Float
  order       Int      @default(0)

  orderItemAddons OrderItemAddon[]

  @@index([courseId])
}


// ============================================
// Siparişler
// ============================================
model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      OrderStatus @default(PENDING)
  totalAmount Float
  
  // Fatura bilgileri
  customerName     String?
  customerEmail    String?
  customerPhone    String?
  customerTc       String?
  customerCity     String?
  customerDistrict String?
  customerAddress  String?   @db.Text
  notes            String?   @db.Text
  
  // Kupon İlişkisi
  couponId      String?
  coupon        Coupon?   @relation(fields: [couponId], references: [id], onDelete: SetNull)

  // Moka POS Doğrulama
  codeForHash   String?

  receiptUrl    String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]
}

enum OrderStatus {
  PENDING     // Beklemede
  PAID        // Ödendi
  FAILED      // Başarısız
  REFUNDED    // İade edildi
}

// ============================================
// Sipariş Kalemleri
// ============================================
model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  variantId String?
  variant   CourseVariant? @relation(fields: [variantId], references: [id])
  price     Float
  quantity  Int      @default(1)

  addons    OrderItemAddon[]

  @@index([orderId])
  @@index([courseId])
  @@index([variantId])
}

model OrderItemAddon {
  id          String       @id @default(cuid())
  orderItemId String
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addonId     String?
  addon       CourseAddon? @relation(fields: [addonId], references: [id])
  addonName   String
  price       Float

  @@index([orderItemId])
}

// ============================================
// Kurs Erişimi
// ============================================
model CourseAccess {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId   String
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  grantedAt DateTime  @default(now())
  expiresAt DateTime? // null = süresiz erişim

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

// ============================================
// Site Ayarları (CMS)
// ============================================
model SiteConfig {
  id           String  @id @default(cuid())
  siteName     String  @default("4T Akademi")
  phone        String  @default("(0312) 433 40 44")
  whatsapp     String  @default("905531724044")
  email        String  @default("destek@4takademi.com")
  address      String  @default("İlkbahar Mah. 593 Sk. No:2 Çankaya/ANKARA") @db.Text
  footerText   String? @db.Text
  workingHours String  @default("09:00 - 19:00")
  headerAnnouncement String? @default("Geleceğe Hazırlık") // Top Bar Anonsu
  heroStats    Json?   // Trust strip istatistikleri {"items": [{label, value}]}
  updatedAt    DateTime @updatedAt
}

// ============================================
// Menü Yönetimi (CMS)
// ============================================
model Menu {
  id        String     @id @default(cuid())
  slug      String     @unique // "footer-urunler", "header-main"
  title     String
  order     Int        @default(0)
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id        String  @id @default(cuid())
  menuId    String
  menu      Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  label     String
  url       String
  desc      String? // Menü açıklaması (dropdown'lar için)
  order     Int     @default(0)
  isActive  Boolean @default(true)

  parentId  String?
  parent    MenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  MenuItem[] @relation("MenuHierarchy")

  @@index([menuId])
  @@index([parentId])
}

// ============================================
// Ana Sayfa Slider
// ============================================
model HeroSlide {
  id          String  @id @default(cuid())
  title       String
  subtitle    String?
  description String? @db.Text
  cta         String? // Buton yazısı
  href        String? // Buton linki
  imageUrl    String?
  order       Int     @default(0)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// Sıkça Sorulan Sorular
// ============================================
model FAQ {
  id       String  @id @default(cuid())
  question String
  answer   String  @db.Text
  category String  @default("genel") // genel, odeme, teknik, flix
  order    Int     @default(0)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Blog Yazıları
// ============================================
model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @db.Text
  excerpt     String?   @db.Text
  imageUrl    String?
  category    String?
  isPublished Boolean   @default(false)
  isFeatured  Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================
// Kuponlar / İndirim Kodları
// ============================================
model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String    @default("PERCENT") // PERCENT veya FIXED
  amount    Float     // % veya ₺ miktar
  minOrder  Float?    // Minimum sipariş tutarı
  maxUses   Int?      // Maksimum kullanım
  usedCount Int       @default(0)
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  courseId   String?
  course    Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  orders    Order[]
}

// ============================================
// Sayfa İçerikleri (Genel CMS)
// ============================================
model PageContent {
  id         String   @id @default(cuid())
  pageSlug   String   // hakkimizda, iletisim, orgun-egitim
  sectionKey String   // hero-title, mission-text, vision-text
  title      String?
  content    String?  @db.Text
  metadata   Json?    // Ekstra veriler (istatistikler, görseller vb.)
  updatedAt  DateTime @updatedAt

  @@unique([pageSlug, sectionKey])
}

// ============================================
// Sayfa İçerik Versiyonları (Geçmiş)
// ============================================
model PageContentVersion {
  id         String   @id @default(cuid())
  pageSlug   String
  snapshot   Json     // Tüm bölümlerin snapshot'ı
  label      String?  // Opsiyonel etiket: "Hero başlığı değiştirildi"
  createdAt  DateTime @default(now())

  @@index([pageSlug, createdAt])
}

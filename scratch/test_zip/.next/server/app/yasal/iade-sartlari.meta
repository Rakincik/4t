{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/yasal/layout,_N_T_/yasal/[slug]/layout,_N_T_/yasal/[slug]/page,_N_T_/yasal/iade-sartlari"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/yasal/$d$slug/__PAGE__",
    "/yasal/$d$slug",
    "/yasal",
    "/_index"
  ]
}
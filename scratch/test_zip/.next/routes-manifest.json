    {
      "source": "/:all*(svg|jpg|jpeg|png|webp|avif|ico|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(svg|jpg|jpeg|png|webp|avif|ico|woff2)(?:/)?$"
    }
  ],
